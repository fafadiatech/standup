# ═══════════════════════════════════════════════════════════════════════════
#  app/.gitignore — Flutter mobile app
#  Based on the official Flutter .gitignore template with project additions.
# ═══════════════════════════════════════════════════════════════════════════

# ─── Dart tool cache ────────────────────────────────────────────────────────
.dart_tool/
.packages

# ─── Flutter plugin manifests (auto-generated) ──────────────────────────────
.flutter-plugins
.flutter-plugins-dependencies

# ─── Build output ───────────────────────────────────────────────────────────
build/

# ─── Android ────────────────────────────────────────────────────────────────
android/.gradle/
android/app/debug/
android/app/profile/
android/app/release/
android/local.properties       # machine-specific SDK path
android/key.properties         # signing credentials — never commit
*.keystore
*.jks
google-services.json           # Firebase config — add via CI secret

# ─── iOS ────────────────────────────────────────────────────────────────────
ios/.symlinks/
ios/Pods/
ios/Runner.xcworkspace/        # regenerated by `pod install`
ios/Flutter/Flutter.framework
ios/Flutter/Flutter.podspec
GoogleService-Info.plist       # Firebase config — add via CI secret

# ─── Coverage ───────────────────────────────────────────────────────────────
coverage/

# ─── IntelliJ / Android Studio ──────────────────────────────────────────────
*.iml
.idea/

# ─── pubspec.lock ────────────────────────────────────────────────────────────
# For application packages, commit pubspec.lock to pin dependencies.
# Uncomment the line below only if this is a reusable library package.
# pubspec.lock
