# ═══════════════════════════════════════════════════════════════════════════
#  standup/.gitignore — ERPNext / Frappe Python app
# ═══════════════════════════════════════════════════════════════════════════

# ─── Python bytecode ────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so

# ─── Packaging / distribution ───────────────────────────────────────────────
*.egg
*.egg-info/
dist/
build/
.eggs/
.Python
pip-wheel-metadata/
RECORD
*.manifest

# ─── Virtual environments ───────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ─── Testing & coverage ─────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# ─── Frappe / Bench runtime artefacts ───────────────────────────────────────
# These are generated by bench and should never be committed from inside
# the app package directory.
node_modules/
.cache/
.parcel-cache/
*.log

# ─── Type-checking ──────────────────────────────────────────────────────────
.mypy_cache/
.ruff_cache/
